# ─── Camera Settings ───────────────────────────────────────────
CAMERA_SOURCE=0                   # 0 = webcam | "rtsp://..." = IP cam | path = video file
CAMERA_WIDTH=1280
CAMERA_HEIGHT=720
CAMERA_FPS=30

# ─── Detection Model ───────────────────────────────────────────
YOLO_MODEL=yolov8m.pt             # nano/small/medium/large/xlarge
DETECTION_CONFIDENCE=0.45
DETECTION_IOU=0.45
DEVICE=cpu                        # cpu | cuda | mps

# ─── Tracking ──────────────────────────────────────────────────
MAX_TRACK_AGE=30
MAX_IOU_DISTANCE=0.7
MAX_COSINE_DISTANCE=0.3
NN_BUDGET=100

# ─── Behavior Analysis ─────────────────────────────────────────
FIGHT_SPEED_THRESHOLD=35.0        # px/frame avg speed for fight detection
FIGHT_OVERLAP_THRESHOLD=0.25      # bounding box IoU for proximity
LOITER_TIME_THRESHOLD=60          # seconds in same zone = loitering
INTRUSION_CHECK=true              # enable restricted zone intrusion
FALL_ASPECT_RATIO_THRESHOLD=1.5   # w/h ratio > this = possible fall
CROWD_PANIC_SPEED=28.0            # collective speed for crowd panic
CROWD_MIN_PERSONS=5               # min people for crowd event

# ─── Motion Analysis ───────────────────────────────────────────
MOTION_SENSITIVITY=500            # min contour area for motion detection
OPTICAL_FLOW_QUALITY=0.3          # Lucas-Kanade quality level

# ─── Alert & Backend ───────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
ALERT_COOLDOWN_SECONDS=5          # min seconds between same-type alerts
SAVE_SNAPSHOTS=true
SNAPSHOT_DIR=./snapshots
ENABLE_ALARM=true
ALARM_DURATION_MS=1500

# ─── Restricted Zones (JSON list of [x1,y1,x2,y2] polygons) ───
# Example: RESTRICTED_ZONES=[[0,0,200,200],[900,0,1280,200]]
RESTRICTED_ZONES=[]

# ─── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./logs/surveillance.log
